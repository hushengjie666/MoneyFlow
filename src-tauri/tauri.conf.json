{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MoneyFlow",
  "version": "0.1.0",
  "identifier": "com.moneyflow.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MoneyFlow",
        "url": "index.html",
        "decorations": false,
        "width": 620,
        "height": 860,
        "minWidth": 560,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/app-icon.png",
      "icons/icon.ico"
    ]
  }
}
