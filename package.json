  "dependencies": {
    "@tauri-apps/api": "^2.8.0",
    "vite": "^5.4.11"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.8.2",
    "eslint": "^8.57.0",
    "prettier": "^3.6.2",
    "vitest": "^3.2.4"
  }
}
