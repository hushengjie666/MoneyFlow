{
  "name": "moneyflow-speckit-v2",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "tauri:dev": "tauri dev --no-watch",
    "tauri:build": "tauri build --debug --no-bundle",
    "tauri:build:full": "tauri build",
    "tauri:build:nsis": "tauri build -b nsis",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "vitest run tests/e2e/frontend-smoke.e2e.test.js",
    "test:all": "npm run lint && npm run test && npm run test:e2e",
